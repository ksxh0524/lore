# Lore 环境配置
# 默认配置，端口在 10000+ 范围内

# 服务端口
LORE_SERVER_PORT=39527
LORE_CLIENT_PORT=39528

# 数据目录
LORE_DATA_DIR=

# 加密密钥 (生产环境请修改)
LORE_ENCRYPTION_KEY=lore-default-encryption-key-32-chars

# 日志级别
LOG_LEVEL=info

# 启用 Mock Provider
ENABLE_MOCK_PROVIDER=true

# API Keys (请在下面添加你的 API Keys)
# DASHSCOPE_API_KEY=your-dashscope-api-key
# OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
